#include<stdio.h>
int main()
{
   int i,j,n,a[10],temp;
   printf("Enter the number of elements to be stored\n");
   scanf("%d",&n);
   printf("Enter the elements one by one\n");
   for(i=0;i<n;i++)
   {
      scanf("%d",&a[i]);
   }
   for(i=0;i<n-1;i++)
   {
    for(j=i+1;j<n;j++)
    {
       if(a[i]>a[j])
       {
          temp=a[i];
          a[i]=a[j];
          a[j]=temp;
       }
    }
   }
   printf("The sorted numbers are\n");
   for(i=0;i<n;i++)
   {
      printf("%d\n",a[i]);
   }
}
