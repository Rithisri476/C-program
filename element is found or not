#include<stdio.h>
int main()
{
   int a[10],i,j,n,t;
   printf("Enter the number of elements to be stored:");
   scanf("%d",&n);
   printf("Enter the element one by one:");
   for(i=0;i<n;i++)
   {
      scanf("%d",&a[i]);
   }
   printf("Enter the elements to be searched:");
   scanf("%d",&j);
   for(i=0;i<n;i++)
   {
      if(a[i]==j)
      {
         t=1;
         break;
      }
   }
   if(t==1)
      printf("Element is found");
   else
      printf("Element is not found");
   return 0;
}
