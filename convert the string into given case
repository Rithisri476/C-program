#include<stdio.h>
#include<string.h>
int main()
{
   int l,choice;
   char a[50],b[50];
   printf("Enter the string:");
   scanf("%s",a);
   printf("Enter the choice:");
   scanf("%d",&choice);
   switch(choice)
   {
      case 1:
         l=strlen(a);
         printf("Length of the string is %d",l);
         break;
      case 2:
         strcpy(b,a);
         printf("Original string is %s",a);
         printf("Copied string is %s",b);
         break;
      case 3:
         printf("Enter string 2:");
         scanf("%s",b);
         strcat(a,b);
         printf("Concatenated string is %s",a);
         break;
      case 4:
         printf("Enter string 2:");
         scanf("%s",b);
         if(strcmp(a,b)==0)
            printf("Strings are equal");
         else
            printf("Strings are not equal");
         break;
      default:
         printf("Enter valid choice");
         break;
   }
   return 0;
}
